{
  "name": "codereview-ai-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "postinstall": "npm run install:all",
    "install:all": "npm install --prefix frontend && npm install --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev": "concurrently --kill-others \"npm run dev:backend\" \"npm run dev:frontend\"",
    "check:frontend": "npm run lint --prefix frontend",
    "check:backend": "npm run lint --prefix backend",
    "check": "npm run check:backend && npm run check:frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
